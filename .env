# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=CHANGE_ME_IN_ENV_LOCAL
# Comma-separated proxy IPs/CIDRs. REMOTE_ADDR trusts the immediate upstream hop.
# Override in .env.local or via cloud environment variables for production.
TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR
# Regex matched against the Host header. Override per environment.
TRUSTED_HOSTS=^(localhost|badi-menu\.your-domain\.com)$
###< symfony/framework-bundle ###

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###

###> docker-compose db service ###
# Credentials for the MariaDB container. Override in .env.local for your environment.
# DB_USER gets only SELECT/INSERT/UPDATE/DELETE/CREATE/ALTER/INDEX/REFERENCES — no DROP, no GRANT.
DB_NAME=db_name
DB_USER=db_user
DB_PASSWORD=db_password
DB_ROOT_PASSWORD=db_root_password
###< docker-compose db service ###

###> doctrine/doctrine-bundle ###
# DATABASE_URL is built from the DB_* variables above — credentials are defined once.
# Override DB_HOST (default: 127.0.0.1) in .env.local when running the app inside Docker (use "db").
DB_HOST=127.0.0.1
DATABASE_URL="mysql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:3306/${DB_NAME}?serverVersion=mariadb-11.5.2&charset=utf8mb4"
###< doctrine/doctrine-bundle ###
