# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must NEVER be committed.
#
# Run:  cp .env.local.dist .env.local
# Then replace every <...> placeholder with an actual value.

###> symfony/framework-bundle ###
# Generate with: php bin/console secrets:generate-keys  OR  openssl rand -hex 32
APP_SECRET=<generate_a_strong_random_secret>
###< symfony/framework-bundle ###

###> symfony/mailer ###
# Examples:
#   smtp://user:pass@smtp.example.com:587
#   gmail+smtp://user:app-password@default
#   sendgrid+smtp://apikey:SG.xxx@default
MAILER_DSN=<mailer_dsn>
###< symfony/mailer ###

###> docker-compose db service ###
# Must match the DB_* variables used to build DATABASE_URL below.
DB_NAME=<database_name>
DB_USER=<database_user>
DB_PASSWORD=<database_password>
DB_ROOT_PASSWORD=<database_root_password>
# When running the app inside Docker, set DB_HOST to the service name: db
DB_HOST=db
###< docker-compose db service ###

###> doctrine/doctrine-bundle ###
# DATABASE_URL is built from the DB_* variables above — no need to repeat credentials here.
# If you need a fully custom URL, you can override it here:
# DATABASE_URL="mysql://<db_user>:<db_password>@<db_host>:3306/<db_name>?serverVersion=mariadb-11.5.2&charset=utf8mb4"
###< doctrine/doctrine-bundle ###