# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must NEVER be committed.
#
# Run:  cp .env.local.dist .env.local
# Then replace every <...> placeholder with an actual value.

###> symfony/framework-bundle ###
# Generate with: php bin/console secrets:generate-keys  OR  openssl rand -hex 32
APP_SECRET=<generate_a_strong_random_secret>
###< symfony/framework-bundle ###

###> symfony/mailer ###
# Examples:
#   smtp://user:pass@smtp.example.com:587
#   gmail+smtp://user:app-password@default
#   sendgrid+smtp://apikey:SG.xxx@default
MAILER_DSN=<mailer_dsn>
###< symfony/mailer ###

###> doctrine/doctrine-bundle ###
# Replace all placeholders with real connection details.
DATABASE_URL="mysql://<db_user>:<db_password>@<db_host>:3306/<db_name>?serverVersion=mariadb-11.5.2"
###< doctrine/doctrine-bundle ###